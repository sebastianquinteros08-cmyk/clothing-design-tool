# fal.ai API key — get one at https://fal.ai/dashboard/keys
# Formato típico: "<key-id>:<key-secret>"
FAL_KEY=your_fal_key_here

# (Opcional) Anthropic API key para parsing NL → DSL (slice 4 en adelante)
# ANTHROPIC_API_KEY=

# (Opcional) Google Gemini API key (alternativa a Anthropic)
# GOOGLE_API_KEY=
